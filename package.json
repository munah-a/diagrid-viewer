{
  "name": "diagrid-viewer",
  "version": "1.0.0",
  "description": "3D structural analysis viewer for diagrid structures with FEM/CFD solvers and Revit integration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.{js,css,html}\" \"tests/**/*.js\""
  },
  "keywords": ["structural-analysis", "fem", "cfd", "three.js", "diagrid", "revit"],
  "license": "MIT",
  "dependencies": {
    "three": "^0.162.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
